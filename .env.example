# ── WhatsApp (Meta) ──────────────────────────────
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=
META_APP_SECRET=            # optional: enable webhook signature verification

# ── STT ──────────────────────────────────────────
# STT_PROVIDER name must match the provider file: app/providers/stt/<name>.py
STT_PROVIDER=orchardrun     # orchardrun | openai | deepgram
STT_LANGUAGE=es

# ── LLM ──────────────────────────────────────────
# LLM_PROVIDER name must match the provider file: app/providers/llm/<name>.py
LLM_PROVIDER=openai         # openai | anthropic | groq | deepseek
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
SYSTEM_PROMPT="You are a helpful voice assistant for a business."

# ── TTS ──────────────────────────────────────────
# TTS_PROVIDER name must match the provider file: app/providers/tts/<name>.py
TTS_PROVIDER=orchardrun     # orchardrun | openai | elevenlabs
TTS_VOICE_ID=es_MX-claude

# ── Orchard Run (shared key for STT + TTS) ──────
ORCHARD_API_KEY=
